@model VgcCollege.Web.Models.CourseEnrollment

<h2>Create Enrollment</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentProfileId"
                asp-items="ViewBag.StudentProfileId"
                class="form-control"></select>
    </div>

    <div class="form-group mt-2">
        <label>Course</label>
        <select asp-for="CourseId"
                asp-items="ViewBag.CourseId"
                class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-success mt-3">
        Create
    </button>

</form>