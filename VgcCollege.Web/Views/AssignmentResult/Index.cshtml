@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>

<h2 class="text-center mt-4">Gradebook</h2>

<div class="text-center mb-3">
    <a asp-action="Create" class="btn btn-success">+ Add Result</a>
</div>

<table class="table table-striped text-center">
    <thead class="table-dark">
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Assignment</th>
            <th>Grade</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.StudentProfile?.Name</td>
                <td>@r.Assignment?.Course?.Name</td>
                <td>@r.Assignment?.Title</td>
                <td>@r.Grade</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>