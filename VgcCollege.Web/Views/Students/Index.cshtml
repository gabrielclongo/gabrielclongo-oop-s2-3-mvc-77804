@model IEnumerable<VgcCollege.Web.Models.StudentProfile>

<h2 class="text-center mt-4 fw-bold">Students Management</h2>

<div class="text-center mb-4">
    <a asp-action="Create" class="btn btn-success px-4 py-2">
        + Add New Student
    </a>
</div>

<div class="container">
    <table class="table table-hover table-bordered text-center shadow">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th style="width: 200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="2" class="text-muted">No students found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>